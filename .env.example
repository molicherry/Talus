# VPS Manager — Environment Variables
# Copy this file to .env and fill in the values.

# Database password for PostgreSQL
DB_PASSWORD=change-me

# Master key for SSH credential encryption (32+ bytes, hex-encoded)
# Generate with: openssl rand -hex 32
VPSMANAGER_MASTER_KEY=change-me-to-64-hex-chars

# JWT signing secret (any random string)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-random-string

# HTTP server port (default: 8080)
PORT=8080

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Monitoring: metrics collection interval in seconds (default: 60)
MONITOR_INTERVAL=60

# SSH connection timeout in seconds (default: 10)
SSH_TIMEOUT=10

# Command execution timeout in seconds (default: 30)
EXEC_TIMEOUT=30
